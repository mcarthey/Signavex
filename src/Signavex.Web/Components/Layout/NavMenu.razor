@* M3 Navigation Rail — icon-first with labels visible on hover/expand *@

<div class="flex flex-col h-full w-full">
    @* Brand *@
    <div class="flex items-center gap-3 px-4 mb-6 h-10 shrink-0">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-primary text-on-primary font-bold text-lg">
            S
        </div>
        <span class="whitespace-nowrap text-white font-semibold text-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            Signavex
        </span>
    </div>

    @* Nav items *@
    <div class="flex flex-col gap-1 px-2 flex-1">
        <NavLink class="no-underline" href="" Match="NavLinkMatch.All">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">Dashboard</span>
            </div>
        </NavLink>

        <NavLink class="no-underline" href="economy">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">Economy</span>
            </div>
        </NavLink>

        <NavLink class="no-underline" href="insights">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">Insights</span>
            </div>
        </NavLink>

        <NavLink class="no-underline" href="backtest">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">
                    Backtest
                    <AuthorizeView Roles="Pro"><NotAuthorized><span class="ml-1 rounded bg-primary/30 px-1 py-0.5 text-[10px] text-primary-container">PRO</span></NotAuthorized></AuthorizeView>
                </span>
            </div>
        </NavLink>

        <NavLink class="no-underline" href="history">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">
                    History
                    <AuthorizeView Roles="Pro"><NotAuthorized><span class="ml-1 rounded bg-primary/30 px-1 py-0.5 text-[10px] text-primary-container">PRO</span></NotAuthorized></AuthorizeView>
                </span>
            </div>
        </NavLink>

        <NavLink class="no-underline" href="about">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">About</span>
            </div>
        </NavLink>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <NavLink class="no-underline" href="admin">
                    <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">Admin</span>
                    </div>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <NavLink class="no-underline" href="settings">
            <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">
                    Settings
                    <AuthorizeView Roles="Pro"><NotAuthorized><span class="ml-1 rounded bg-primary/30 px-1 py-0.5 text-[10px] text-primary-container">PRO</span></NotAuthorized></AuthorizeView>
                </span>
            </div>
        </NavLink>
    </div>

    @* Auth *@
    <div class="px-2 pb-4 shrink-0">
        <AuthorizeView>
            <Authorized>
                <form method="post" action="/account/logout">
                    <button type="submit"
                            class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white">
                        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
                        </svg>
                        <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">Sign Out</span>
                    </button>
                </form>
            </Authorized>
            <NotAuthorized>
                <NavLink class="no-underline" href="account/login">
                    <div class="flex h-10 w-full items-center gap-3 rounded-[var(--radius-sm)] px-4 text-white/70 transition-colors duration-150 hover:bg-[var(--color-nav-hover)] hover:text-white [.active>&]:bg-[var(--color-nav-active)] [.active>&]:text-white">
                        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                        </svg>
                        <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-medium">Sign In</span>
                    </div>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>
