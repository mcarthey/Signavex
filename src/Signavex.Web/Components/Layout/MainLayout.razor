@inherits LayoutComponentBase

<div class="flex min-h-screen bg-surface">
    @* CSS-only mobile nav toggle — a hidden checkbox driving the drawer state.
       This pattern works in static SSR where Blazor @onclick handlers do not
       fire (no SignalR circuit). Clicking the hamburger label or the backdrop
       label toggles the checkbox; CSS peer-checked rules handle the visibility.
       The input is accessibility-named via aria-hidden since the label carries
       the semantic meaning. *@
    <input type="checkbox" id="mobile-nav-toggle" class="peer hidden" aria-hidden="true" />

    @* M3 Navigation Rail — desktop only *@
    <nav class="group fixed left-0 top-0 z-40 flex h-screen w-[72px] flex-col items-center bg-nav py-4 transition-all duration-300 ease-[cubic-bezier(0.2,0,0,1)] hover:w-60 overflow-hidden max-md:hidden">
        <NavMenu />
    </nav>

    @* Mobile header — hamburger + brand *@
    <div class="fixed top-0 left-0 right-0 z-40 flex h-14 items-center bg-nav px-4 md:hidden">
        <label for="mobile-nav-toggle" class="text-white/70 hover:text-white p-2 -ml-2 cursor-pointer" aria-label="Open menu">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </label>
        <span class="ml-3 text-white font-semibold text-lg">Signavex</span>
    </div>

    @* Mobile drawer — visible only when the peer checkbox is checked *@
    <div class="fixed inset-0 z-50 md:hidden hidden peer-checked:block">
        <label for="mobile-nav-toggle" class="absolute inset-0 bg-black/50 cursor-pointer" aria-label="Close menu"></label>
        <nav class="absolute left-0 top-0 h-full w-60 bg-nav py-4 animate-slide-in">
            <NavMenu />
        </nav>
    </div>

    @* Main content area *@
    <main class="flex-1 md:ml-[72px] mt-14 md:mt-0 min-h-screen w-full min-w-0">
        <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
            @Body
        </div>

        <footer class="border-t border-outline-variant/20 py-4 text-center text-xs text-on-surface-variant px-4">
            <a href="/terms" class="hover:text-primary transition-colors">Terms of Service</a>
            <span class="mx-2">|</span>
            <a href="/privacy" class="hover:text-primary transition-colors">Privacy Policy</a>
            <span class="block sm:inline mt-1 sm:mt-0 sm:mx-4">&copy; 2026 Signavex</span>
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    Something went wrong. Please reload the page.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">&#x2715;</a>
</div>
