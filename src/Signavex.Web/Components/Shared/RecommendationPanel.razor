@using Signavex.Domain.Analysis
@using Signavex.Web.Services
@inject EconomicDashboardService EconService

<div>
    @* Profile selector *@
    <div class="flex items-center gap-2 mb-4">
        <label class="text-sm text-on-surface-variant">Profile:</label>
        <select class="rounded-[var(--radius-sm)] border border-outline bg-surface-container px-3 py-1.5 text-sm text-on-surface"
                value="@_selectedProfile" @onchange="OnProfileChanged">
            @foreach (var p in Enum.GetValues<UserProfile>())
            {
                <option value="@p">@UserProfileLabels.GetLabel(p)</option>
            }
        </select>
    </div>

    @if (_plan is not null)
    {
        @* Summary *@
        <p class="text-sm text-on-surface-variant mb-4">@_plan.Summary</p>

        @* Recommendations *@
        <div class="flex flex-col gap-3">
            @foreach (var rec in _plan.Recommendations)
            {
                <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container p-4">
                    <div class="flex items-start justify-between mb-1">
                        <h4 class="text-sm font-semibold text-on-surface">@rec.Title</h4>
                        <span class="text-xs font-medium px-2 py-0.5 rounded-full shrink-0 ml-2 @GetPriorityClass(rec.Priority)">
                            @rec.Priority
                        </span>
                    </div>
                    <p class="text-sm text-on-surface-variant mb-2">@rec.Description</p>
                    <p class="text-xs text-on-surface-variant italic">@rec.Reasoning</p>
                </div>
            }
        </div>

        @if (_plan.Recommendations.Count == 0)
        {
            <p class="text-sm text-on-surface-variant">No specific recommendations for this profile at this time.</p>
        }

        @* Outlook *@
        <div class="mt-4 p-3 rounded-[var(--radius-sm)] bg-surface-container-highest">
            <h4 class="text-xs font-semibold text-on-surface-variant uppercase mb-1">Economic Outlook</h4>
            <p class="text-sm text-on-surface">@_plan.EconomicOutlook</p>
        </div>
    }
</div>

@code {
    private UserProfile _selectedProfile = UserProfile.General;
    private ActionPlan? _plan;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecommendations();
    }

    private async Task OnProfileChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<UserProfile>(e.Value?.ToString(), out var profile))
        {
            _selectedProfile = profile;
            await LoadRecommendations();
        }
    }

    private async Task LoadRecommendations()
    {
        _plan = await EconService.GetRecommendationsAsync(_selectedProfile);
    }

    private static string GetPriorityClass(string priority) => priority switch
    {
        "critical" => "bg-error/20 text-error",
        "high" => "bg-warning/20 text-warning",
        "medium" => "bg-outline-variant/30 text-on-surface-variant",
        _ => "bg-primary/15 text-primary"
    };
}
