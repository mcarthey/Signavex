@using Signavex.Domain.Models

@if (Context is not null)
{
    <div class="alert @AlertCss mb-3" role="alert">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <strong>Market Context:</strong> @Context.Summary
            </div>
            <span class="badge bg-dark fs-6">@Context.Multiplier.ToString("F2")x</span>
        </div>
        @if (ShowDetails)
        {
            <hr class="my-2" />
            <div class="row g-2">
                @foreach (var signal in Context.MarketSignals)
                {
                    <div class="col-md-3 col-sm-6">
                        <small class="text-muted">@signal.SignalName</small><br />
                        <span class="fw-bold @(signal.Score >= 0 ? "text-success" : "text-danger")">
                            @signal.Score.ToString("+0.00;-0.00")
                        </span>
                        <small class="d-block text-muted">@signal.Reason</small>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public MarketContext? Context { get; set; }

    [Parameter]
    public bool ShowDetails { get; set; } = true;

    private string AlertCss => Context?.Multiplier switch
    {
        >= 1.2 => "alert-success",
        >= 0.9 => "alert-info",
        _ => "alert-warning"
    };
}
