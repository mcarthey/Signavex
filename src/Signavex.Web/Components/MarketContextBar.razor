@using Signavex.Domain.Models

@if (Context is not null)
{
    <div class="rounded-[var(--radius-md)] border @BorderCss p-4 mb-4 @BgCss">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] @IconBgCss">
                    @if (Context.Multiplier >= 1.2)
                    {
                        <svg class="h-4 w-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                        </svg>
                    }
                    else if (Context.Multiplier >= 0.9)
                    {
                        <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                        </svg>
                    }
                    else
                    {
                        <svg class="h-4 w-4 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181" />
                        </svg>
                    }
                </div>
                <div>
                    <p class="text-sm font-medium text-on-surface">@Context.Summary</p>
                </div>
            </div>
            <span class="rounded-[var(--radius-full)] @MultiplierCss px-3 py-1 text-sm font-semibold">
                @Context.Multiplier.ToString("F2")x
            </span>
        </div>

        @if (ShowDetails && Context.MarketSignals.Any())
        {
            <div class="mt-3 pt-3 border-t border-outline-variant">
                <div class="flex flex-wrap gap-2">
                    @foreach (var signal in Context.MarketSignals)
                    {
                        var desc = GetSignalDescription(signal.SignalName);
                        <details class="group">
                            <summary class="inline-flex items-center gap-1.5 rounded-[var(--radius-sm)] bg-surface-container px-3 py-1.5 text-xs transition-colors hover:bg-surface-container-high cursor-pointer list-none">
                                <span class="font-medium text-on-surface-variant">@FormatSignalName(signal.SignalName)</span>
                                <span class="font-semibold @(signal.Score >= 0 ? "text-success" : "text-error")">
                                    @signal.Score.ToString("+0.00;-0.00")
                                </span>
                                <svg class="h-3 w-3 text-on-surface-variant transition-transform group-open:rotate-180"
                                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                                </svg>
                            </summary>
                            <div class="mt-2 rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container-lowest p-3 max-w-md">
                                <div class="flex items-center gap-3 mb-2">
                                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-[var(--radius-xs)] @(signal.Score >= 0 ? "bg-success-container" : "bg-error-container")">
                                        <span class="text-xs font-bold @(signal.Score >= 0 ? "text-success" : "text-error")">
                                            @signal.Score.ToString("+0.0;-0.0")
                                        </span>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-on-surface">@FormatSignalName(signal.SignalName)</p>
                                        <p class="text-xs text-on-surface-variant">Weight: @signal.Weight.ToString("F1")x</p>
                                    </div>
                                </div>
                                <p class="text-xs text-on-surface-variant leading-relaxed">@signal.Reason</p>
                                @if (!string.IsNullOrEmpty(desc))
                                {
                                    <p class="text-[10px] text-on-surface-variant/60 mt-2">@desc</p>
                                }
                            </div>
                        </details>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public MarketContext? Context { get; set; }

    [Parameter]
    public bool ShowDetails { get; set; } = true;

    private static string FormatSignalName(string name)
    {
        // Insert spaces before uppercase letters: "MarketTrend" → "Market Trend"
        return System.Text.RegularExpressions.Regex.Replace(name, "(?<!^)([A-Z])", " $1");
    }

    private static string GetSignalDescription(string signalName) => signalName switch
    {
        "MarketTrend" => "Compares S&P 500 price against 50-day and 200-day moving averages. Positive when the market is in an uptrend.",
        "InterestRateEnvironment" => "Evaluates the Federal Funds rate trend. Lower or declining rates are favorable for equities.",
        "VixLevel" => "Measures market volatility via the VIX index. Low VIX (< 20) signals calm markets; high VIX (> 30) signals fear.",
        "SectorMomentum" => "Tracks recent performance momentum across market sectors to gauge breadth of market participation.",
        "EconomicHealth" => "Composite of GDP growth, unemployment, and consumer confidence indicators.",
        _ => ""
    };

    private string BgCss => Context?.Multiplier switch
    {
        >= 1.2 => "bg-success-container/30",
        >= 0.9 => "bg-primary-container/20",
        _ => "bg-warning-container/30"
    };

    private string BorderCss => Context?.Multiplier switch
    {
        >= 1.2 => "border-success/30",
        >= 0.9 => "border-primary/20",
        _ => "border-warning/30"
    };

    private string IconBgCss => Context?.Multiplier switch
    {
        >= 1.2 => "bg-success-container",
        >= 0.9 => "bg-primary-container",
        _ => "bg-warning-container"
    };

    private string MultiplierCss => Context?.Multiplier switch
    {
        >= 1.2 => "bg-success text-on-success",
        >= 0.9 => "bg-primary text-on-primary",
        _ => "bg-warning text-on-primary"
    };
}
