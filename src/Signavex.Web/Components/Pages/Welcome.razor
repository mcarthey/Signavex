@page "/welcome"
@attribute [Authorize]

<PageTitle>Welcome — Signavex</PageTitle>

<div class="flex min-h-[60vh] items-center justify-center animate-fade-in">
    <div class="w-full max-w-lg text-center">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-[var(--radius-lg)] bg-primary text-on-primary font-bold text-2xl">
            S
        </div>

        <h1 class="text-2xl font-bold text-on-surface mb-2">Welcome to Signavex</h1>
        <p class="text-sm text-on-surface-variant mb-8">
            Signavex watches the economy and market every day and tells you what's interesting in plain English.
        </p>

        <div class="grid gap-4 sm:grid-cols-3 mb-8 text-left">
            @* Card 1: Today's Brief *@
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container p-4">
                <div class="flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] bg-primary/15 mb-3">
                    <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                    </svg>
                </div>
                <h3 class="text-sm font-semibold text-on-surface mb-1">Read today's brief</h3>
                <p class="text-xs text-on-surface-variant">A daily summary of what's happening in the market, written in plain English.</p>
            </div>

            @* Card 2: Economy *@
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container p-4">
                <div class="flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] bg-primary/15 mb-3">
                    <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
                    </svg>
                </div>
                <h3 class="text-sm font-semibold text-on-surface mb-1">Browse the economy</h3>
                <p class="text-xs text-on-surface-variant">Live indicators of where the economy is headed, with health scores and trends.</p>
            </div>

            @* Card 3: Stock Picks *@
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container p-4">
                <div class="flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] bg-primary/15 mb-3">
                    <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625z" />
                    </svg>
                </div>
                <h3 class="text-sm font-semibold text-on-surface mb-1">See today's stock picks</h3>
                <p class="text-xs text-on-surface-variant">Stocks our system flagged as interesting, scored across 13 different signals.</p>
            </div>
        </div>

        <p class="text-xs text-on-surface-variant mb-6">
            You have <strong>7 days of free access</strong> to explore everything Signavex has to offer.
        </p>

        <form method="post" action="/welcome/complete">
            <AntiforgeryToken />
            <button type="submit"
                    class="rounded-[var(--radius-sm)] bg-primary px-8 py-3 text-sm font-medium text-on-primary transition-colors hover:bg-primary/90">
                Start with today's brief
            </button>
        </form>
    </div>
</div>
