@code {
    private bool _authenticated;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            _authenticated = true;

            // Smart redirect for authenticated users: onboarding → trial check → today
            var user = await UserManager.FindByNameAsync(authState.User.Identity.Name!);
            if (user is not null)
            {
                if (!user.HasCompletedOnboarding)
                {
                    Navigation.NavigateTo("/welcome", forceLoad: true);
                    return;
                }

                if (user.TrialStartedAt.HasValue
                    && user.TrialStartedAt.Value.AddDays(7) < DateTime.UtcNow
                    && !authState.User.IsInRole("Pro") && !authState.User.IsInRole("Admin"))
                {
                    Navigation.NavigateTo("/trial-expired", forceLoad: true);
                    return;
                }
            }

            Navigation.NavigateTo("/today", forceLoad: true);
        }
    }
}
