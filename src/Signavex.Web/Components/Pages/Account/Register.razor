@page "/account/register"
@using Microsoft.AspNetCore.Identity
@using Signavex.Infrastructure.Persistence
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<PageTitle>Register — Signavex</PageTitle>

<div class="flex min-h-[60vh] items-center justify-center">
    <div class="w-full max-w-sm">
        <div class="mb-8 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-[var(--radius-md)] bg-primary text-on-primary font-bold text-xl">
                S
            </div>
            <h1 class="text-2xl font-bold text-on-surface">Create an account</h1>
        </div>

        @if (_errors.Count > 0)
        {
            <div class="mb-4 rounded-[var(--radius-sm)] bg-error/15 px-4 py-3 text-sm text-error">
                <ul class="list-disc pl-4 space-y-1">
                    @foreach (var error in _errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <form method="post" @onsubmit="HandleRegister" @formname="register">
            <AntiforgeryToken />

            <div class="space-y-4">
                <div>
                    <label for="email" class="block text-sm font-medium text-on-surface mb-1">Email</label>
                    <input id="email" name="Input.Email" type="email" value="@Input.Email" required autocomplete="username"
                           class="w-full rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container px-3 py-2 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-on-surface mb-1">Password</label>
                    <input id="password" name="Input.Password" type="password" required autocomplete="new-password"
                           class="w-full rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container px-3 py-2 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                </div>

                <div>
                    <label for="confirmPassword" class="block text-sm font-medium text-on-surface mb-1">Confirm Password</label>
                    <input id="confirmPassword" name="Input.ConfirmPassword" type="password" required autocomplete="new-password"
                           class="w-full rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container px-3 py-2 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                </div>

                <button type="submit"
                        class="w-full rounded-[var(--radius-sm)] bg-primary px-4 py-2 text-sm font-medium text-on-primary transition-colors hover:bg-primary/90">
                    Create Account
                </button>
            </div>
        </form>

        @if (_googleEnabled)
        {
            <div class="mt-4 flex items-center gap-3">
                <div class="flex-1 border-t border-outline-variant"></div>
                <span class="text-xs text-on-surface-variant">or</span>
                <div class="flex-1 border-t border-outline-variant"></div>
            </div>

            <a href="/account/login-google"
               class="mt-4 flex w-full items-center justify-center gap-2 rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container px-4 py-2 text-sm font-medium text-on-surface transition-colors hover:bg-surface-container-highest no-underline">
                <svg class="h-4 w-4" viewBox="0 0 24 24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Sign up with Google
            </a>
        }

        <p class="mt-6 text-center text-sm text-on-surface-variant">
            Already have an account?
            <a href="/account/login" class="text-primary hover:underline">Sign in</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private RegisterInput Input { get; set; } = new();

    private List<string> _errors = new();
    private bool _googleEnabled;

    protected override void OnInitialized()
    {
        Input ??= new();
        _googleEnabled = !string.IsNullOrEmpty(Configuration["Google:ClientId"]);
    }

    private async Task HandleRegister()
    {
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(Input.Email) || string.IsNullOrWhiteSpace(Input.Password))
        {
            _errors.Add("Please fill in all fields.");
            return;
        }

        if (Input.Password != Input.ConfirmPassword)
        {
            _errors.Add("Passwords do not match.");
            return;
        }

        var user = new ApplicationUser
        {
            UserName = Input.Email,
            Email = Input.Email,
            TrialStartedAt = DateTime.UtcNow
        };
        var result = await UserManager.CreateAsync(user, Input.Password);

        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, "Free");
            await SignInManager.SignInAsync(user, isPersistent: true);
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            foreach (var error in result.Errors)
            {
                _errors.Add(error.Description);
            }
        }
    }

    private sealed class RegisterInput
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
