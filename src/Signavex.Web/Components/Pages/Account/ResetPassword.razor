@page "/account/reset-password"
@using Microsoft.AspNetCore.Identity
@using Signavex.Infrastructure.Persistence
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Reset Password — Signavex</PageTitle>

<div class="flex min-h-[60vh] items-center justify-center">
    <div class="w-full max-w-sm">
        <div class="mb-8 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-[var(--radius-md)] bg-primary text-on-primary font-bold text-xl">
                S
            </div>
            <h1 class="text-2xl font-bold text-on-surface">Set new password</h1>
        </div>

        @if (_succeeded)
        {
            <div class="rounded-[var(--radius-sm)] bg-success/15 px-4 py-3 text-sm text-success mb-4">
                Your password has been reset successfully.
            </div>
            <p class="text-center">
                <a href="/account/login" class="text-primary font-medium hover:underline">Sign in with your new password</a>
            </p>
        }
        else
        {
            @if (_errors.Count > 0)
            {
                <div class="mb-4 rounded-[var(--radius-sm)] bg-error/15 px-4 py-3 text-sm text-error">
                    <ul class="list-disc pl-4 space-y-1">
                        @foreach (var error in _errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <form method="post" @onsubmit="HandleReset" @formname="reset-password">
                <AntiforgeryToken />
                <input type="hidden" name="Input.Email" value="@Input.Email" />
                <input type="hidden" name="Input.Token" value="@Input.Token" />

                <div class="space-y-4">
                    <div>
                        <label for="password" class="block text-sm font-medium text-on-surface mb-1">New Password</label>
                        <input id="password" name="Input.Password" type="password" required autocomplete="new-password"
                               class="w-full rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container px-3 py-2 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                    </div>

                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium text-on-surface mb-1">Confirm Password</label>
                        <input id="confirmPassword" name="Input.ConfirmPassword" type="password" required autocomplete="new-password"
                               class="w-full rounded-[var(--radius-sm)] border border-outline-variant bg-surface-container px-3 py-2 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                    </div>

                    <button type="submit"
                            class="w-full rounded-[var(--radius-sm)] bg-primary px-4 py-2 text-sm font-medium text-on-primary transition-colors hover:bg-primary/90">
                        Reset Password
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private ResetPasswordInput Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? Token { get; set; }

    private List<string> _errors = new();
    private bool _succeeded;

    protected override void OnInitialized()
    {
        Input ??= new();
        if (!string.IsNullOrEmpty(Email)) Input.Email = Email;
        if (!string.IsNullOrEmpty(Token)) Input.Token = Token;
    }

    private async Task HandleReset()
    {
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(Input.Password))
        {
            _errors.Add("Please enter a new password.");
            return;
        }

        if (Input.Password != Input.ConfirmPassword)
        {
            _errors.Add("Passwords do not match.");
            return;
        }

        if (string.IsNullOrWhiteSpace(Input.Email) || string.IsNullOrWhiteSpace(Input.Token))
        {
            _errors.Add("Invalid reset link. Please request a new one.");
            return;
        }

        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            _errors.Add("Invalid reset link. Please request a new one.");
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Input.Token, Input.Password);
        if (result.Succeeded)
        {
            _succeeded = true;
        }
        else
        {
            foreach (var error in result.Errors)
                _errors.Add(error.Description);
        }
    }

    private sealed class ResetPasswordInput
    {
        public string Email { get; set; } = "";
        public string Token { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
