@page "/account/upgrade-success"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Upgrade Complete — Signavex</PageTitle>

<div class="flex min-h-[60vh] items-center justify-center">
    <div class="w-full max-w-sm text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-[var(--radius-md)] bg-primary text-on-primary font-bold text-xl">
            S
        </div>
        <h1 class="text-2xl font-bold text-on-surface mb-4">Welcome to Pro!</h1>
        <p class="text-on-surface-variant mb-6">
            Your subscription is active. You now have full access to all Signavex features including
            complete scan results, historical data, backtesting, and custom settings.
        </p>
        <a href="/"
           class="inline-block rounded-[var(--radius-sm)] bg-primary px-6 py-2 text-sm font-medium text-on-primary transition-colors hover:bg-primary/90">
            Go to Dashboard
        </a>
    </div>
</div>
