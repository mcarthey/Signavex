@page "/"
@page "/dashboard"
@attribute [Authorize]
@using Signavex.Domain.Configuration
@using Signavex.Domain.Enums
@using Signavex.Domain.Helpers
@using Signavex.Domain.Models
@using Signavex.Web.Services
@using Microsoft.Extensions.Options
@inject ScanDashboardService DashboardService
@inject ApiKeyValidationService ApiKeyService
@inject IOptions<SignavexOptions> Options
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Signavex Dashboard</PageTitle>

<div class="animate-fade-in">
    @* Header *@
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-on-surface tracking-tight">Dashboard</h1>
            @if (_lastScanTime.HasValue)
            {
                <p class="text-sm text-on-surface-variant mt-0.5">
                    Last scan @RelativeTime(_lastScanTime.Value)
                    @if (_lastScanErrors > 0)
                    {
                        <span class="text-warning"> · @_lastScanErrors stock(s) skipped</span>
                    }
                </p>
            }
        </div>
        <div class="flex items-center gap-2">
            @if (DisplayResults.Any())
            {
                <button class="inline-flex items-center gap-1.5 rounded-[var(--radius-sm)] border border-outline px-3 py-2 text-sm font-medium text-on-surface-variant transition-colors hover:bg-surface-container"
                        @onclick="ExportCsv">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    CSV
                </button>
            }
            <button class="inline-flex items-center gap-2 rounded-[var(--radius-xl)] bg-primary px-5 py-2.5 text-sm font-medium text-on-primary shadow-elevation-1 transition-all duration-150 hover:shadow-elevation-2 hover:brightness-110 disabled:opacity-50 disabled:cursor-not-allowed"
                    @onclick="RunScan" disabled="@(_scanStatus?.IsScanning == true || _scanRequested)">
                @if (_scanStatus?.IsScanning == true)
                {
                    <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Scanning...</span>
                }
                else if (_scanRequested)
                {
                    <span>Scan Requested</span>
                }
                else
                {
                    <span>Run Scan</span>
                }
            </button>
        </div>
    </div>

    @* API Key Warning *@
    @if (!ApiKeyService.HasAllKeys)
    {
        var missing = ApiKeyService.GetMissingKeys();
        <div class="mb-4 flex items-start gap-3 rounded-[var(--radius-md)] border border-warning/30 bg-warning-container/30 p-4">
            <svg class="h-5 w-5 shrink-0 text-warning mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
                <p class="text-sm font-medium text-on-surface">API keys not configured</p>
                <p class="text-sm text-on-surface-variant mt-0.5">
                    Missing: @string.Join(", ", missing).
                    Scans will fail or return incomplete data. Configure keys in
                    <a href="/settings" class="text-primary font-medium hover:underline">Settings</a>.
                </p>
            </div>
        </div>
    }

    @* Scan Progress *@
    @if (_scanStatus?.IsScanning == true)
    {
        var s = _scanStatus;
        <div class="mb-4 rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-4">
            <div class="flex items-center justify-between text-sm mb-2">
                <span class="font-medium text-on-surface">
                    Evaluating @s.CurrentTicker
                </span>
                <span class="text-on-surface-variant">
                    @s.Evaluated / @s.Total
                    @if (EstimatedTimeRemaining(s) is { } eta)
                    {
                        <span> · ~@FormatEta(eta) remaining</span>
                    }
                </span>
            </div>
            <div class="h-2 w-full rounded-[var(--radius-full)] bg-surface-container-high overflow-hidden">
                <div class="h-full rounded-[var(--radius-full)] bg-primary transition-all duration-300 animate-pulse-bar"
                     style="width: @(s.Total > 0 ? (s.Evaluated * 100 / s.Total) : 0)%"></div>
            </div>
            <div class="flex items-center justify-between mt-1.5">
                @if (s.ErrorCount > 0)
                {
                    <p class="text-xs text-warning">@s.ErrorCount error(s) so far</p>
                }
                else
                {
                    <span></span>
                }
                @if (s.CandidatesFound > 0)
                {
                    <p class="text-xs text-success font-medium">@s.CandidatesFound candidate(s) found</p>
                }
            </div>
        </div>
    }

    @* Market Context *@
    <MarketContextBar Context="_marketContext" />

    @* Results *@
    @if (!DisplayResults.Any() && _scanStatus?.IsScanning != true)
    {
        @if (_lastScanTime.HasValue && _marketContext is not null)
        {
            @* Scan completed with 0 candidates — show rich summary *@
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-5">
                <h3 class="text-base font-semibold text-on-surface mb-4">Last Scan Summary</h3>

                @* Stats row *@
                <div class="grid grid-cols-3 gap-4 mb-4">
                    <div class="rounded-[var(--radius-sm)] bg-surface-container p-3 text-center">
                        <p class="text-2xl font-bold text-on-surface">@_totalEvaluated.ToString("N0")</p>
                        <p class="text-xs text-on-surface-variant mt-0.5">Stocks Evaluated</p>
                    </div>
                    <div class="rounded-[var(--radius-sm)] bg-surface-container p-3 text-center">
                        <p class="text-2xl font-bold text-on-surface">0</p>
                        <p class="text-xs text-on-surface-variant mt-0.5">Candidates Found</p>
                    </div>
                    <div class="rounded-[var(--radius-sm)] bg-surface-container p-3 text-center">
                        <p class="text-2xl font-bold @(_marketContext.Multiplier >= 1.0 ? "text-success" : "text-warning")">
                            @_marketContext.Multiplier.ToString("F2")x
                        </p>
                        <p class="text-xs text-on-surface-variant mt-0.5">Market Multiplier</p>
                    </div>
                </div>

                @* Market signals breakdown *@
                @if (_marketContext.MarketSignals.Any())
                {
                    <h4 class="text-sm font-medium text-on-surface mb-2">Market Signals</h4>
                    <div class="grid gap-2 sm:grid-cols-2 mb-4">
                        @foreach (var signal in _marketContext.MarketSignals.OrderByDescending(s => Math.Abs(s.Score * s.Weight)))
                        {
                            <div class="rounded-[var(--radius-sm)] bg-surface-container px-3 py-2">
                                <div class="flex items-center justify-between mb-0.5">
                                    <span class="text-sm font-medium text-on-surface">@FormatSignalName(signal.SignalName)</span>
                                    <span class="text-sm font-semibold @(signal.Score >= 0 ? "text-success" : "text-error")">
                                        @signal.Score.ToString("+0.00;-0.00")
                                    </span>
                                </div>
                                @if (!string.IsNullOrEmpty(signal.Reason))
                                {
                                    <p class="text-xs text-on-surface-variant">@signal.Reason</p>
                                }
                            </div>
                        }
                    </div>
                }

                @* Educational explanation *@
                <div class="rounded-[var(--radius-sm)] border border-outline-variant/50 bg-surface-container/50 p-3">
                    <p class="text-sm font-medium text-on-surface mb-1">Why no candidates?</p>
                    <p class="text-sm text-on-surface-variant leading-relaxed">
                        @MarketExplanation()
                    </p>
                </div>
            </div>
        }
        else
        {
            @* No scan has ever run — generic empty state *@
            <div class="flex flex-col items-center justify-center py-16 text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-[var(--radius-lg)] bg-surface-container mb-4">
                    <svg class="h-8 w-8 text-on-surface-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-on-surface">No candidates yet</h3>
                <p class="mt-1 text-sm text-on-surface-variant max-w-sm">
                    Click <strong>Run Scan</strong> to evaluate the stock universe and discover candidates.
                </p>
            </div>
        }
    }
    else if (DisplayResults.Any())
    {
        @if (_scanStatus?.IsScanning == true)
        {
            <h3 class="text-sm font-semibold text-on-surface-variant mb-3 flex items-center gap-2">
                <span class="h-2 w-2 rounded-full bg-success animate-pulse"></span>
                Candidates Found So Far (@DisplayResults.Count())
            </h3>
        }

        @* Filter chips *@
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <button class="@ChipCss(_tierFilter == "")" @onclick='() => _tierFilter = ""'>All Tiers</button>
            <button class="@ChipCss(_tierFilter == "SP500")" @onclick='() => _tierFilter = "SP500"'>S&P 500</button>
            <button class="@ChipCss(_tierFilter == "SP400")" @onclick='() => _tierFilter = "SP400"'>S&P 400</button>
            <button class="@ChipCss(_tierFilter == "SP600")" @onclick='() => _tierFilter = "SP600"'>S&P 600</button>

            <span class="mx-1 h-4 w-px bg-outline-variant"></span>

            <button class="@ChipCss(_sortBy == "score")" @onclick='() => _sortBy = "score"'>By Score</button>
            <button class="@ChipCss(_sortBy == "ticker")" @onclick='() => _sortBy = "ticker"'>A-Z</button>
            <button class="@ChipCss(_sortBy == "raw")" @onclick='() => _sortBy = "raw"'>Raw Score</button>
        </div>

        @* Candidate cards *@
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var candidate in FilteredResults)
            {
                <a href="/candidate/@candidate.Ticker"
                   class="group rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-4 shadow-elevation-1 transition-all duration-150 hover:shadow-elevation-2 hover:border-primary/30 no-underline">
                    <div class="flex items-start justify-between mb-2">
                        <div>
                            <span class="text-base font-bold text-on-surface">@candidate.Ticker</span>
                            <p class="text-xs text-on-surface-variant mt-0.5 truncate max-w-[150px]">@candidate.CompanyName</p>
                        </div>
                        <ScoreBadge Score="candidate.FinalScore" />
                    </div>
                    <div class="flex items-center gap-3 text-xs text-on-surface-variant">
                        <span class="rounded-[var(--radius-xs)] bg-surface-container px-1.5 py-0.5 font-medium">@candidate.Tier</span>
                        <span>Raw: @candidate.RawScore.ToString("F3")</span>
                        <span>@candidate.SignalResults.Count(s => s.IsAvailable) signals</span>
                    </div>
                </a>
            }
        </div>

        <p class="mt-3 text-xs text-on-surface-variant">
            @FilteredResults.Count() of @DisplayResults.Count() candidates shown
        </p>
    }
</div>

<Disclaimer />

@code {
    private string _tierFilter = "";
    private string _sortBy = "score";

    private ScanStatus? _scanStatus;
    private MarketContext? _marketContext;
    private IReadOnlyList<StockCandidate> _latestResults = Array.Empty<StockCandidate>();
    private IReadOnlyList<StockCandidate> _liveCandidates = Array.Empty<StockCandidate>();
    private DateTime? _lastScanTime;
    private int _lastScanErrors;
    private int _totalEvaluated;
    private bool _scanRequested;

    private Timer? _pollTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadLatestResults();
        await PollStatus();

        _pollTimer = new Timer(async _ =>
        {
            try
            {
                await PollStatus();
                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                // Timer callback — swallow to avoid crashing the circuit
            }
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    private async Task LoadLatestResults()
    {
        try
        {
            var result = await DashboardService.GetLatestResultAsync();
            if (result is not null)
            {
                _latestResults = result.Candidates;
                _marketContext = result.MarketContext;
                _lastScanTime = result.CompletedAtUtc;
                _lastScanErrors = result.ErrorCount;
                _totalEvaluated = result.TotalEvaluated;
            }
        }
        catch
        {
            // Persist layer unavailable
        }
    }

    private async Task PollStatus()
    {
        try
        {
            _scanStatus = await DashboardService.GetScanStatusAsync();

            if (_scanStatus.IsScanning)
            {
                _scanRequested = false;
                _liveCandidates = await DashboardService.GetLiveCandidatesAsync();
                _marketContext = await DashboardService.GetMarketContextAsync();
            }
            else
            {
                // If scan just completed, reload the latest results
                if (_liveCandidates.Count > 0)
                {
                    await LoadLatestResults();
                    _liveCandidates = Array.Empty<StockCandidate>();
                }
            }
        }
        catch
        {
            // Poll failure — skip this cycle
        }
    }

    private IEnumerable<StockCandidate> DisplayResults
    {
        get
        {
            if (_scanStatus?.IsScanning == true && _liveCandidates.Count > 0)
                return _liveCandidates;

            return _latestResults;
        }
    }

    private IEnumerable<StockCandidate> FilteredResults
    {
        get
        {
            var results = DisplayResults;

            if (!string.IsNullOrEmpty(_tierFilter) && Enum.TryParse<MarketTier>(_tierFilter, out var tier))
                results = results.Where(c => c.Tier == tier);

            results = _sortBy switch
            {
                "ticker" => results.OrderBy(c => c.Ticker),
                "raw" => results.OrderByDescending(c => c.RawScore),
                _ => results.OrderByDescending(c => c.FinalScore)
            };

            return results;
        }
    }

    private async Task RunScan()
    {
        _scanRequested = true;
        await DashboardService.RequestScanAsync();
    }

    private async Task ExportCsv()
    {
        if (_latestResults.Count == 0)
            return;

        var csv = CsvExportHelper.GenerateCsv(_latestResults);
        var fileName = $"signavex-scan-{DateTime.UtcNow:yyyy-MM-dd}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, csv);
    }

    private static string RelativeTime(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        if (elapsed.TotalMinutes < 1) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        return $"{(int)elapsed.TotalDays}d ago";
    }

    private static TimeSpan? EstimatedTimeRemaining(ScanStatus s)
    {
        if (s.StartedAtUtc is null || s.Evaluated <= 0 || s.Total <= 0)
            return null;

        var elapsed = DateTime.UtcNow - s.StartedAtUtc.Value;
        var avgPerStock = elapsed / s.Evaluated;
        var remaining = s.Total - s.Evaluated;
        return avgPerStock * remaining;
    }

    private static string FormatEta(TimeSpan eta)
    {
        if (eta.TotalMinutes < 1) return "<1m";
        if (eta.TotalHours < 1) return $"{(int)eta.TotalMinutes}m";
        return $"{(int)eta.TotalHours}h {eta.Minutes}m";
    }

    private static string ChipCss(bool active) => active
        ? "rounded-[var(--radius-sm)] bg-primary text-on-primary px-3 py-1.5 text-xs font-medium transition-colors"
        : "rounded-[var(--radius-sm)] bg-surface-container text-on-surface-variant px-3 py-1.5 text-xs font-medium transition-colors hover:bg-surface-container-high";

    private string MarketExplanation()
    {
        var threshold = Options.Value.SurfacingThreshold;
        var mult = _marketContext!.Multiplier;

        if (mult < 0.7)
            return $"Market conditions are very bearish (multiplier {mult:F2}x). " +
                   $"Every stock's raw score is multiplied by {mult:F2}, meaning a stock would need a raw score above " +
                   $"{threshold / mult:F2} to clear the {threshold:F2} surfacing threshold. " +
                   "In conditions like these, even strong individual stocks struggle to surface.";

        if (mult < 0.9)
            return $"Market conditions are challenging (multiplier {mult:F2}x). " +
                   $"The market multiplier reduces all final scores, so stocks need a raw score above " +
                   $"{threshold / mult:F2} to clear the {threshold:F2} surfacing threshold. " +
                   "Fewer stocks meet this bar when the broader market is under pressure.";

        if (mult < 1.0)
            return $"Market conditions are slightly unfavorable (multiplier {mult:F2}x). " +
                   $"Stocks need a raw score above {threshold / mult:F2} to reach the " +
                   $"{threshold:F2} surfacing threshold. " +
                   "Even a small headwind from market conditions can push borderline candidates below the cutoff.";

        return $"Market conditions are neutral to favorable (multiplier {mult:F2}x), " +
               $"yet no stocks reached the {threshold:F2} surfacing threshold. " +
               "This can happen when individual stock signals (volume, trend, analyst ratings) are mixed or weak across the board.";
    }

    private static string FormatSignalName(string name)
    {
        // "MarketTrend" → "Market Trend", "VixLevel" → "Vix Level"
        var sb = new System.Text.StringBuilder(name.Length + 4);
        for (int i = 0; i < name.Length; i++)
        {
            if (i > 0 && char.IsUpper(name[i]) && !char.IsUpper(name[i - 1]))
                sb.Append(' ');
            sb.Append(name[i]);
        }
        return sb.ToString();
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }
}
