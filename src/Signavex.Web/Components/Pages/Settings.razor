@page "/settings"
@using Signavex.Domain.Configuration
@using Signavex.Web.Services
@using Microsoft.Extensions.Options
@inject IOptionsMonitor<SignavexOptions> OptionsMonitor
@inject ApiKeyValidationService ApiKeyService
@rendermode InteractiveServer

<PageTitle>Settings — Signavex</PageTitle>

<div class="animate-fade-in">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-on-surface tracking-tight">Settings</h1>
        <p class="text-sm text-on-surface-variant mt-0.5">Current signal weight configuration</p>
    </div>

    @* API Key Status *@
    <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-5 shadow-elevation-1 mb-4">
        <h3 class="text-base font-semibold text-on-surface mb-3">API Keys</h3>
        <div class="space-y-2">
            @foreach (var (name, configured) in GetKeyStatus())
            {
                <div class="flex items-center gap-2">
                    @if (configured)
                    {
                        <div class="h-2 w-2 rounded-full bg-success"></div>
                        <span class="text-sm text-on-surface">@name</span>
                        <span class="text-xs text-success">Configured</span>
                    }
                    else
                    {
                        <div class="h-2 w-2 rounded-full bg-error"></div>
                        <span class="text-sm text-on-surface">@name</span>
                        <span class="text-xs text-error">Not configured</span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        @* Stock Signals *@
        <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-5 shadow-elevation-1">
            <h3 class="text-base font-semibold text-on-surface mb-3">Stock Signals (Tier 2)</h3>
            <div class="space-y-2">
                @foreach (var (name, weight) in GetStockSignals())
                {
                    <div class="flex items-center justify-between py-1">
                        <span class="text-sm text-on-surface">@name</span>
                        <span class="rounded-[var(--radius-xs)] bg-surface-container px-2 py-0.5 text-xs font-medium text-on-surface-variant">
                            @weight.ToString("F1")
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="space-y-4">
            @* Market Signals *@
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-5 shadow-elevation-1">
                <h3 class="text-base font-semibold text-on-surface mb-3">Market Signals (Tier 1)</h3>
                <div class="space-y-2">
                    @foreach (var (name, weight) in GetMarketSignals())
                    {
                        <div class="flex items-center justify-between py-1">
                            <span class="text-sm text-on-surface">@name</span>
                            <span class="rounded-[var(--radius-xs)] bg-surface-container px-2 py-0.5 text-xs font-medium text-on-surface-variant">
                                @weight.ToString("F1")
                            </span>
                        </div>
                    }
                </div>
            </div>

            @* General *@
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-5 shadow-elevation-1">
                <h3 class="text-base font-semibold text-on-surface mb-3">General</h3>
                <div class="space-y-2">
                    <div class="flex items-center justify-between py-1">
                        <span class="text-sm text-on-surface">Surfacing Threshold</span>
                        <span class="rounded-[var(--radius-xs)] bg-surface-container px-2 py-0.5 text-xs font-medium text-on-surface-variant">
                            @_options.SurfacingThreshold.ToString("F2")
                        </span>
                    </div>
                    <div class="flex items-center justify-between py-1">
                        <span class="text-sm text-on-surface">Universe</span>
                        <span class="rounded-[var(--radius-xs)] bg-surface-container px-2 py-0.5 text-xs font-medium text-on-surface-variant">
                            @string.Join(", ", _options.Universe)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 rounded-[var(--radius-md)] border border-primary/20 bg-primary-container/10 p-4">
        <p class="text-sm text-on-surface-variant">
            To modify weights or API keys, edit <code class="rounded bg-surface-container px-1 py-0.5 text-xs font-mono text-on-surface">appsettings.json</code> and restart the application.
        </p>
    </div>
</div>

@code {
    private SignavexOptions _options = new();
    private SignalWeightsOptions _weights = new();
    private MarketSignalWeightsOptions _marketWeights = new();

    protected override void OnInitialized()
    {
        _options = OptionsMonitor.CurrentValue;
        _weights = _options.SignalWeights;
        _marketWeights = _options.MarketSignalWeights;
    }

    private IEnumerable<(string Name, double Weight)> GetStockSignals() => new[]
    {
        ("Volume Threshold", _weights.VolumeThreshold),
        ("Moving Average Crossover", _weights.MovingAverageCrossover),
        ("Support/Resistance", _weights.SupportResistance),
        ("Trend Direction", _weights.TrendDirection),
        ("Channel Position", _weights.ChannelPosition),
        ("News Sentiment", _weights.NewsSentiment),
        ("Analyst Rating", _weights.AnalystRating),
        ("P/E vs Industry", _weights.PeRatioVsIndustry),
        ("Debt/Equity Ratio", _weights.DebtEquityRatio),
        ("Earnings Trend", _weights.EarningsTrend)
    };

    private IEnumerable<(string Name, double Weight)> GetMarketSignals() => new[]
    {
        ("Market Trend", _marketWeights.MarketTrend),
        ("Interest Rate Environment", _marketWeights.InterestRateEnvironment),
        ("VIX Level", _marketWeights.VixLevel),
        ("Sector Momentum", _marketWeights.SectorMomentum)
    };

    private IEnumerable<(string Name, bool Configured)> GetKeyStatus()
    {
        var missing = ApiKeyService.GetMissingKeys();
        return new[]
        {
            ("Polygon", !missing.Any(m => m.Contains("Polygon"))),
            ("Alpha Vantage", !missing.Any(m => m.Contains("Alpha"))),
            ("FRED", !missing.Any(m => m.Contains("FRED")))
        };
    }
}
