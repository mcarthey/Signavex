@page "/Error"
@using System.Diagnostics

<PageTitle>Error — Signavex</PageTitle>

<div class="flex min-h-[60vh] items-center justify-center">
    <div class="w-full max-w-md text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-[var(--radius-lg)] bg-error-container">
            <svg class="h-8 w-8 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
        </div>
        <h1 class="text-2xl font-bold text-on-surface mb-2">Something went wrong</h1>
        <p class="text-sm text-on-surface-variant mb-6">
            An unexpected error occurred. Please try again, or return to the dashboard.
        </p>
        @if (ShowRequestId)
        {
            <p class="text-xs text-on-surface-variant mb-4">
                Request ID: <code class="rounded bg-surface-container px-1 py-0.5 text-xs font-mono">@RequestId</code>
            </p>
        }
        <a href="/"
           class="inline-block rounded-[var(--radius-sm)] bg-primary px-6 py-2 text-sm font-medium text-on-primary transition-colors hover:bg-primary/90">
            Go to Dashboard
        </a>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
