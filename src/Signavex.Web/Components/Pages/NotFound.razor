@page "/not-found"

<PageTitle>Page Not Found — Signavex</PageTitle>

<div class="flex min-h-[60vh] items-center justify-center">
    <div class="w-full max-w-md text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-[var(--radius-lg)] bg-surface-container">
            <svg class="h-8 w-8 text-on-surface-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
            </svg>
        </div>
        <h1 class="text-4xl font-bold text-on-surface mb-2">404</h1>
        <p class="text-sm text-on-surface-variant mb-6">
            The page you're looking for doesn't exist or has been moved.
        </p>
        <a href="/"
           class="inline-block rounded-[var(--radius-sm)] bg-primary px-6 py-2 text-sm font-medium text-on-primary transition-colors hover:bg-primary/90">
            Go to Dashboard
        </a>
    </div>
</div>
