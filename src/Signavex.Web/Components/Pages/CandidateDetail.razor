@page "/candidate/{Ticker}"
@using Signavex.Domain.Models
@using Signavex.Web.Services
@inject ScanResultsService ScanService
@inject NavigationManager Nav

<PageTitle>@Ticker — Signavex</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Ticker</li>
    </ol>
</nav>

@if (_candidate is null)
{
    <div class="alert alert-warning">
        Candidate <strong>@Ticker</strong> not found in the latest scan results.
        <a href="/dashboard">Return to dashboard</a>.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>@_candidate.Ticker <small class="text-muted">@_candidate.CompanyName</small></h1>
            <span class="badge bg-secondary me-2">@_candidate.Tier</span>
            <small class="text-muted">Evaluated: @_candidate.EvaluatedAt.ToString("g") UTC</small>
        </div>
        <div class="text-end">
            <div class="mb-1"><small class="text-muted">Raw Score</small></div>
            <div class="fs-4">@_candidate.RawScore.ToString("F3")</div>
            <div class="mt-2"><small class="text-muted">Final Score</small></div>
            <div class="fs-3"><ScoreBadge Score="_candidate.FinalScore" /></div>
        </div>
    </div>

    <MarketContextBar Context="_candidate.MarketContext" ShowDetails="false" />

    <h3 class="mt-4">Signal Breakdown</h3>
    <SignalBreakdown Signals="_candidate.SignalResults" />
}

@code {
    [Parameter]
    public string Ticker { get; set; } = "";

    private StockCandidate? _candidate;

    protected override void OnParametersSet()
    {
        _candidate = ScanService.LatestResults
            .FirstOrDefault(c => c.Ticker.Equals(Ticker, StringComparison.OrdinalIgnoreCase));
    }
}
