@page "/picks/{Ticker}"
@page "/candidate/{Ticker}"
@attribute [Authorize]
@using Signavex.Domain.Interfaces
@using Signavex.Domain.Models
@using Signavex.Web.Components.Shared
@inject IScanHistoryStore HistoryStore
@inject IScanStateStore StateStore
@inject IMarketDataProvider MarketData
@inject INewsDataProvider NewsData
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@Ticker — Signavex</PageTitle>

<div class="animate-fade-in">
    @* Breadcrumb *@
    <nav class="mb-4 flex items-center gap-1.5 text-sm text-on-surface-variant">
        <a href="/picks" class="hover:text-primary transition-colors">Stock Picks</a>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
        <span class="font-medium text-on-surface">@Ticker</span>
    </nav>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-16">
            <div class="h-6 w-6 animate-spin rounded-full border-2 border-primary border-t-transparent"></div>
        </div>
    }
    else if (!_isPro && !_isInFreeLimit)
    {
        <div class="flex flex-col items-center justify-center py-16 text-center">
            <h3 class="text-base font-semibold text-on-surface mb-4">@Ticker</h3>
            <UpgradePrompt Title="Unlock Full Candidate Details"
                           Description="Free accounts can view details for the top 5 candidates. Upgrade to Pro for access to all candidate breakdowns." />
        </div>
    }
    else if (_candidate is null)
    {
        <div class="flex flex-col items-center justify-center py-16 text-center">
            <div class="flex h-12 w-12 items-center justify-center rounded-[var(--radius-md)] bg-warning-container mb-3">
                <svg class="h-6 w-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                </svg>
            </div>
            <h3 class="text-base font-semibold text-on-surface">Candidate not found</h3>
            <p class="mt-1 text-sm text-on-surface-variant">
                <strong>@Ticker</strong> is not in the latest scan results.
            </p>
            <a href="/picks" class="mt-3 text-sm font-medium text-primary hover:underline">Return to stock picks</a>
        </div>
    }
    else
    {
        @* Header card *@
        <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-5 shadow-elevation-1 mb-4">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-on-surface">@_candidate.Ticker</h1>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        @(_profile?.Name ?? _candidate.CompanyName)
                    </p>
                    <div class="flex items-center gap-2 mt-2 flex-wrap">
                        <span class="rounded-[var(--radius-xs)] bg-surface-container px-2 py-0.5 text-xs font-medium text-on-surface-variant">
                            @_candidate.Tier
                        </span>
                        @if (_profile?.Sector is not null)
                        {
                            <span class="rounded-[var(--radius-xs)] bg-tertiary-container px-2 py-0.5 text-xs font-medium text-on-primary-container">
                                @_profile.Sector
                            </span>
                        }
                        @if (_profile?.Industry is not null)
                        {
                            <span class="rounded-[var(--radius-xs)] bg-secondary-container px-2 py-0.5 text-xs font-medium text-on-secondary-container">
                                @_profile.Industry
                            </span>
                        }
                        <span class="text-xs text-on-surface-variant">
                            Evaluated @_candidate.EvaluatedAt.ToString("g") UTC
                        </span>
                    </div>
                </div>
                <div class="flex items-center gap-6">
                    <div class="text-center">
                        <p class="text-xs text-on-surface-variant mb-1">Raw Score</p>
                        <p class="text-xl font-bold text-on-surface">@_candidate.RawScore.ToString("F3")</p>
                    </div>
                    <div class="text-center">
                        <p class="text-xs text-on-surface-variant mb-1">Final Score</p>
                        <div class="text-xl"><ScoreBadge Score="_candidate.FinalScore" /></div>
                    </div>
                </div>
            </div>

            @* Score formula *@
            <div class="mt-4 pt-3 border-t border-outline-variant">
                <p class="text-xs text-on-surface-variant">
                    Score:
                    <span class="font-semibold text-on-surface">@_candidate.RawScore.ToString("F3")</span>
                    <span class="mx-1">raw</span>
                    <span class="mx-1">&times;</span>
                    <span class="font-semibold text-on-surface">@_candidate.MarketContext.Multiplier.ToString("F2")</span>
                    <span class="mx-1">market</span>
                    <span class="mx-1">=</span>
                    <span class="font-semibold text-on-surface">@_candidate.FinalScore.ToString("F3")</span>
                    <span class="mx-1">final</span>
                </p>
            </div>
        </div>

        @* Company profile *@
        @if (_profile?.Description is not null)
        {
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-4 shadow-elevation-1 mb-4">
                <details>
                    <summary class="cursor-pointer text-sm font-semibold text-on-surface select-none flex items-center gap-2">
                        <svg class="h-4 w-4 text-on-surface-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                        </svg>
                        About @(_profile.Name)
                    </summary>
                    <div class="mt-3 space-y-3">
                        <p class="text-xs text-on-surface-variant leading-relaxed">
                            @TruncateDescription(_profile.Description)
                        </p>
                        <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-on-surface-variant">
                            @if (_profile.MarketCap.HasValue)
                            {
                                <span>
                                    <span class="font-medium text-on-surface">Market Cap:</span>
                                    @FormatMarketCap(_profile.MarketCap.Value)
                                </span>
                            }
                            @if (_profile.Employees.HasValue)
                            {
                                <span>
                                    <span class="font-medium text-on-surface">Employees:</span>
                                    @_profile.Employees.Value.ToString("N0")
                                </span>
                            }
                            @if (_profile.HomePageUrl is not null)
                            {
                                <a href="@_profile.HomePageUrl" target="_blank" rel="noopener"
                                   class="text-primary hover:underline">
                                    Website
                                    <svg class="inline h-3 w-3 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                    </svg>
                                </a>
                            }
                        </div>
                    </div>
                </details>
            </div>
        }

        @* Market context (expanded) *@
        <MarketContextBar Context="_candidate.MarketContext" ShowDetails="true" />

        @* Price chart *@
        @if (_ohlcv is not null && _ohlcv.Count > 0)
        {
            <PriceChart OhlcvData="_ohlcv"
                        Sma14="_sma14"
                        Sma30="_sma30"
                        Support="_support"
                        Resistance="_resistance"
                        Markers="_chartMarkers"
                        Annotations="_chartAnnotations" />
        }

        @* Score History *@
        @if (_tickerHistory is not null && _tickerHistory.Appearances.Count > 1)
        {
            <div class="rounded-[var(--radius-md)] border border-outline-variant bg-surface-container-lowest p-4 shadow-elevation-1 mb-4">
                <h3 class="text-sm font-semibold text-on-surface mb-3">Score History</h3>
                <div class="flex items-end gap-1 h-24">
                    @foreach (var appearance in _tickerHistory.Appearances)
                    {
                        var barHeight = Math.Max(4, (int)(appearance.FinalScore / _maxHistoryScore * 100));
                        <div class="flex-1 flex flex-col items-center gap-1 min-w-0 group relative">
                            <div class="w-full max-w-[2rem] rounded-t-[var(--radius-xs)] transition-colors @BarCss(appearance.FinalScore)"
                                 style="height: @(barHeight)%"
                                 title="@appearance.ScanDate.ToString("MMM d") — @appearance.FinalScore.ToString("F2")">
                            </div>
                        </div>
                    }
                </div>
                <div class="flex items-end gap-1 mt-1">
                    @foreach (var appearance in _tickerHistory.Appearances)
                    {
                        <div class="flex-1 text-center min-w-0">
                            <span class="text-[9px] text-on-surface-variant truncate block">@appearance.ScanDate.ToString("M/d")</span>
                        </div>
                    }
                </div>
                <p class="text-xs text-on-surface-variant mt-2">
                    Appeared in @_tickerHistory.Appearances.Count scan@(_tickerHistory.Appearances.Count == 1 ? "" : "s")
                </p>
            </div>
        }

        @* Signal Breakdown — grouped *@
        @if (_bullishSignals.Any())
        {
            <h3 class="text-sm font-semibold text-success mb-2 mt-4">
                Bullish Signals (@_bullishSignals.Count)
            </h3>
            <SignalBreakdown Signals="_bullishSignals" />
        }

        @if (_bearishSignals.Any())
        {
            <h3 class="text-sm font-semibold text-error mb-2 mt-4">
                Bearish Signals (@_bearishSignals.Count)
            </h3>
            <SignalBreakdown Signals="_bearishSignals" />
        }

        @if (_neutralSignals.Any())
        {
            <h3 class="text-sm font-semibold text-on-surface-variant mb-2 mt-4">
                Neutral Signals (@_neutralSignals.Count)
            </h3>
            <SignalBreakdown Signals="_neutralSignals" />
        }

        @if (_unavailableSignals.Any())
        {
            <h3 class="text-sm font-semibold text-on-surface-variant mb-2 mt-4">
                Unavailable Signals (@_unavailableSignals.Count)
            </h3>
            <SignalBreakdown Signals="_unavailableSignals" />
        }
    }
</div>

@code {
    [Parameter]
    public string Ticker { get; set; } = "";

    private StockCandidate? _candidate;
    private TickerHistory? _tickerHistory;
    private bool _loading = true;
    private bool _isPro;
    private bool _isInFreeLimit;
    private double _maxHistoryScore = 1.0;

    private List<SignalResult> _bullishSignals = new();
    private List<SignalResult> _bearishSignals = new();
    private List<SignalResult> _neutralSignals = new();
    private List<SignalResult> _unavailableSignals = new();

    // Company profile
    private TickerProfile? _profile;

    // Chart data
    private IReadOnlyList<OhlcvRecord>? _ohlcv;
    private List<PriceChart.ChartPoint>? _sma14;
    private List<PriceChart.ChartPoint>? _sma30;
    private decimal? _support;
    private decimal? _resistance;
    private List<PriceChart.ChartMarker>? _chartMarkers;
    private List<PriceChart.ChartAnnotation>? _chartAnnotations;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isPro = authState.User.IsInRole("Pro") || authState.User.IsInRole("Admin");

        // Load from persisted latest scan
        try
        {
            var latest = await StateStore.LoadLatestResultAsync();
            _candidate = latest?.Candidates
                .FirstOrDefault(c => c.Ticker.Equals(Ticker, StringComparison.OrdinalIgnoreCase));

            // Check if this ticker is in the top 5 (free user limit)
            if (!_isPro && latest?.Candidates is not null)
            {
                var top5 = latest.Candidates
                    .OrderByDescending(c => c.FinalScore)
                    .Take(5)
                    .Select(c => c.Ticker);
                _isInFreeLimit = top5.Contains(Ticker, StringComparer.OrdinalIgnoreCase);
            }
            else
            {
                _isInFreeLimit = true;
            }
        }
        catch
        {
            // Persist layer unavailable — leave _candidate null
            _isInFreeLimit = true;
        }

        // Group signals
        if (_candidate is not null)
        {
            var signals = _candidate.SignalResults.ToList();
            _unavailableSignals = signals.Where(s => !s.IsAvailable).ToList();
            var available = signals.Where(s => s.IsAvailable).ToList();
            _bullishSignals = available.Where(s => s.Score > 0).ToList();
            _bearishSignals = available.Where(s => s.Score < 0).ToList();
            _neutralSignals = available.Where(s => s.Score == 0).ToList();
        }

        // Load ticker history
        try
        {
            _tickerHistory = await HistoryStore.GetTickerHistoryAsync(Ticker);
            if (_tickerHistory is not null && _tickerHistory.Appearances.Count > 0)
            {
                _maxHistoryScore = _tickerHistory.Appearances.Max(a => Math.Abs(a.FinalScore));
                if (_maxHistoryScore == 0) _maxHistoryScore = 1.0;
            }
        }
        catch
        {
            // History unavailable — no chart shown
        }

        // Load chart + profile data inline (static SSR — must be ready before render)
        if (_candidate is not null && (_isPro || _isInFreeLimit))
        {
            await LoadChartDataAsync();
            await LoadProfileAsync();
        }

        _loading = false;
    }

    private async Task LoadChartDataAsync()
    {
        try
        {
            // Fetch 90 days of OHLCV (gives ~60 trading days for good MA coverage)
            var ohlcvList = (await MarketData.GetDailyOhlcvAsync(Ticker, 90)).ToList();
            if (ohlcvList.Count == 0) return;

            _ohlcv = ohlcvList;

            // Compute simple moving averages
            _sma14 = ComputeSma(ohlcvList, 14);
            _sma30 = ComputeSma(ohlcvList, 30);

            // Support & resistance from 20-day rolling min/max
            var recent = ohlcvList.TakeLast(20).ToList();
            if (recent.Count > 0)
            {
                _support = recent.Min(r => r.Low);
                _resistance = recent.Max(r => r.High);
            }

            // Load news and create chart markers
            try
            {
                var news = await NewsData.GetRecentNewsAsync(Ticker, 90);
                _chartMarkers = new List<PriceChart.ChartMarker>();
                _chartAnnotations = new List<PriceChart.ChartAnnotation>();

                var ohlcvDates = new HashSet<string>(ohlcvList.Select(d => d.Date.ToString("yyyy-MM-dd")));

                foreach (var item in news.Take(20))
                {
                    var dateStr = DateOnly.FromDateTime(item.PublishedAt).ToString("yyyy-MM-dd");
                    // Only add marker if we have a candle for that date
                    if (!ohlcvDates.Contains(dateStr)) continue;

                    var sentimentColor = item.SentimentScore switch
                    {
                        > 0.2 => "#16a34a",
                        < -0.2 => "#dc2626",
                        _ => "#4f46e5"
                    };

                    _chartMarkers.Add(new PriceChart.ChartMarker(
                        dateStr,
                        TruncateHeadline(item.Headline),
                        "belowBar",
                        sentimentColor,
                        "circle"
                    ));

                    var summary = !string.IsNullOrWhiteSpace(item.Summary)
                        ? item.Summary
                        : item.Headline;
                    var source = !string.IsNullOrWhiteSpace(item.Source) ? $" ({item.Source})" : "";
                    _chartAnnotations.Add(new PriceChart.ChartAnnotation(
                        dateStr,
                        $"{summary}{source}"
                    ));
                }

                // Add volume spike annotations from signal data
                AddVolumeAnnotations(ohlcvList);
            }
            catch
            {
                // News load failed — chart still works without markers
            }
        }
        catch
        {
            // OHLCV load failed — no chart shown
        }
    }

    private static List<PriceChart.ChartPoint> ComputeSma(IReadOnlyList<OhlcvRecord> data, int period)
    {
        var result = new List<PriceChart.ChartPoint>();
        for (int i = period - 1; i < data.Count; i++)
        {
            var avg = 0m;
            for (int j = i - period + 1; j <= i; j++)
                avg += data[j].Close;
            avg /= period;

            result.Add(new PriceChart.ChartPoint(
                data[i].Date.ToString("yyyy-MM-dd"),
                (double)avg
            ));
        }
        return result;
    }

    private void AddVolumeAnnotations(IReadOnlyList<OhlcvRecord> data)
    {
        if (data.Count < 21) return;

        _chartAnnotations ??= new();

        // Find volume spikes (> 2x 20-day average)
        for (int i = 20; i < data.Count; i++)
        {
            var avgVol = 0L;
            for (int j = i - 20; j < i; j++)
                avgVol += data[j].Volume;
            avgVol /= 20;

            if (avgVol > 0 && data[i].Volume > avgVol * 2)
            {
                var dateStr = data[i].Date.ToString("yyyy-MM-dd");
                var ratio = (double)data[i].Volume / avgVol;

                // Don't duplicate if there's already a news annotation for this date
                if (_chartAnnotations.Any(a => a.Date == dateStr)) continue;

                _chartAnnotations.Add(new PriceChart.ChartAnnotation(
                    dateStr,
                    $"Volume spike: {ratio:F1}x average ({data[i].Volume:N0} vs {avgVol:N0} avg)"
                ));
            }
        }
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            _profile = await MarketData.GetTickerProfileAsync(Ticker);
        }
        catch
        {
            // Profile load failed — page still works
        }
    }

    private static string TruncateDescription(string desc)
    {
        if (desc.Length <= 300) return desc;
        // Cut at last space before 300 chars
        var cut = desc.LastIndexOf(' ', 300);
        return cut > 0 ? desc[..cut] + "..." : desc[..300] + "...";
    }

    private static string FormatMarketCap(long cap)
    {
        if (cap >= 1_000_000_000_000) return $"${cap / 1_000_000_000_000.0:F1}T";
        if (cap >= 1_000_000_000) return $"${cap / 1_000_000_000.0:F1}B";
        if (cap >= 1_000_000) return $"${cap / 1_000_000.0:F0}M";
        return $"${cap:N0}";
    }

    private static string TruncateHeadline(string headline)
    {
        // Markers have limited space — keep it short
        if (headline.Length <= 20) return headline;
        return headline[..17] + "...";
    }

    private static string BarCss(double score) => score switch
    {
        >= 0.75 => "bg-success",
        >= 0.65 => "bg-warning",
        _ => "bg-error"
    };
}
