@* M3 tonal score pill *@

<span class="@CssClass">@Score.ToString("F2")</span>

@code {
    [Parameter, EditorRequired]
    public double Score { get; set; }

    private string CssClass => Score switch
    {
        >= 0.75 => "inline-flex items-center rounded-[var(--radius-full)] bg-success px-2.5 py-0.5 text-xs font-semibold text-on-success",
        >= 0.65 => "inline-flex items-center rounded-[var(--radius-full)] bg-warning-container px-2.5 py-0.5 text-xs font-semibold text-on-surface",
        _ => "inline-flex items-center rounded-[var(--radius-full)] bg-error-container px-2.5 py-0.5 text-xs font-semibold text-error"
    };
}
