<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="css/app.built.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body class="bg-surface text-on-surface font-sans antialiased">
    <Routes />
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script src="js/download.js"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 5,
                    retryIntervalMilliseconds: 2000
                }
            }
        }).then(() => {
            // When all reconnect attempts fail, reload the page to get a fresh circuit
            const observer = new MutationObserver(() => {
                const modal = document.getElementById('components-reconnect-modal');
                if (modal && modal.classList.contains('components-reconnect-failed')) {
                    location.reload();
                }
            });
            observer.observe(document.body, { subtree: true, attributes: true, attributeFilter: ['class'] });
        });
    </script>
</body>

</html>
