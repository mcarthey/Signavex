{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Web: Run (Local)",
      "type": "shell",
      "command": "dotnet run --project src/Signavex.Web",
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Functions: Run (Local)",
      "type": "shell",
      "command": "func start --csharp",
      "options": {
        "cwd": "${workspaceFolder}/src/Signavex.Functions"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build All",
      "type": "shell",
      "command": "dotnet build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Test All",
      "type": "shell",
      "command": "dotnet test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
